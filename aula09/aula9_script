# 13. Final summary
# ---------------------------------------------

cat("\n=============================================\n")
cat("FINAL SUMMARY\n")
cat("=============================================\n")
cat(sprintf("Genotypes             : %d\n", I))
cat(sprintf("Environments          : %d\n", J))
cat(sprintf("Blocks                : %d\n", K))
cat(sprintf("Observations          : %d\n", nrow(dat)))
cat(sprintf("Var(random intercept) : %.2f\n", sigma2_u0))
cat(sprintf("Var(random slope)     : %.2f\n", sigma2_u1))
cat(sprintf("Cov(intercept,slope)  : %.2f\n", sigma_u01))
cat(sprintf("Cor(intercept,slope)  : %.3f\n", cor_u01))
cat(sprintf("Residual variance     : %.2f\n", sigma2_e))
cat("=============================================\n") # Summarize the main outputs of the lesson.
